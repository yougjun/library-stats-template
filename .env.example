# Database
DATABASE_URL=postgresql://user:password@localhost:5432/library_stats

# Security
SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment
ENVIRONMENT=development

# Library Identity
LIBRARY_NAME=My Library
TEMPLATE_FILENAME=library_statistics

# Weather API (Korea Meteorological Administration)
WEATHER_API_KEY=your-weather-api-key

# Google AI (for chat features)
GEMINI_API_KEY=your-gemini-api-key

# LLM Provider (gemini | openai | anthropic)
LLM_PROVIDER=gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local API
LOCAL_API_KEY=your-local-api-key

# Security (CSRF)
CSRF_SECRET=your-csrf-secret

# RAG / Vector Store
CHROMADB_PATH=data/chromadb

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
